---
import { getRouteKeyFromPath, LOCALE_CODES, ROUTE_GROUPS } from '../data/routes.ts';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, any>;
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const site = 'https://casadosduques.pt';
const fullUrl = canonical ? `${site}${canonical}` : site;
const defaultOgImage = ogImage || `${site}/og-default.jpg`;

// Hreflang tags: only emit translated alternates when a real route exists.
const currentPath = Astro.url.pathname;
const routeKey = getRouteKeyFromPath(canonical || currentPath);
const alternates = routeKey
  ? LOCALE_CODES.map(code => ({ code, href: ROUTE_GROUPS[routeKey][code] }))
  : [{ code: 'en', href: canonical || currentPath }];
const xDefaultHref = routeKey ? ROUTE_GROUPS[routeKey].en : canonical || currentPath;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={fullUrl} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={fullUrl} />
<meta property="og:image" content={defaultOgImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
{alternates.map(loc => (
  <link rel="alternate" hreflang={loc.code} href={`${site}${loc.href}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${site}${xDefaultHref}`} />
{ schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} /> }
