---
import { LOCALES } from '../data/site-config.ts';
import { getLocaleFromPath, getLocalizedPath } from '../data/routes.ts';

const currentPath = Astro.url.pathname;
const currentLocale = getLocaleFromPath(currentPath);
---

<div class="flex gap-1 items-center">
  {LOCALES.map(loc => {
    const href = getLocalizedPath(currentPath, loc.code);
    const isActive = loc.code === currentLocale;
    return (
      <a
        href={href}
        class={`px-2.5 py-1.5 text-xs rounded-full transition-colors ${
          isActive
            ? 'bg-olive-900 text-white font-semibold'
            : 'text-slate-warm hover:text-olive-900 hover:bg-olive-50'
        }`}
        aria-label={loc.label}
        aria-current={isActive ? 'true' : undefined}
      >
        {loc.code.toUpperCase()}
      </a>
    );
  })}
</div>
