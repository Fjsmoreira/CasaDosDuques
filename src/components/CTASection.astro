---
export interface Props {
  title: string;
  subtitle?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'terracotta' | 'olive' | 'cream';
}

const { title, subtitle, primaryCta, secondaryCta, variant = 'terracotta' } = Astro.props;

const bgClasses: Record<string, string> = {
  terracotta: 'bg-terracotta-600 text-white',
  olive: 'bg-olive-700 text-white',
  cream: 'bg-warm-cream text-olive-900',
};

const ctaClasses: Record<string, string> = {
  terracotta: 'bg-white text-terracotta-700 hover:bg-warm-cream',
  olive: 'bg-white text-olive-700 hover:bg-warm-cream',
  cream: 'bg-terracotta-500 text-white hover:bg-terracotta-600',
};

const secondaryClasses: Record<string, string> = {
  terracotta: 'border-white/40 text-white/90 hover:bg-white/10',
  olive: 'border-white/40 text-white/90 hover:bg-white/10',
  cream: 'border-terracotta-300 text-terracotta-700 hover:bg-terracotta-50',
};
---

<section class={`${bgClasses[variant]} py-16 md:py-20`}>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
    {subtitle && <p class="text-lg md:text-xl opacity-90 mb-8">{subtitle}</p>}
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={primaryCta.href} class={`inline-block font-semibold px-8 py-3 rounded-lg transition-colors text-lg ${ctaClasses[variant]}`}>
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class={`inline-block font-semibold px-8 py-3 rounded-lg border transition-colors text-lg ${secondaryClasses[variant]}`}>
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
