---
export interface Props {
  title: string;
  subtitle?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'terracotta' | 'olive' | 'cream';
}

const { title, subtitle, primaryCta, secondaryCta, variant = 'terracotta' } = Astro.props;

const bgClasses: Record<string, string> = {
  terracotta: 'bg-olive-50 text-olive-900',
  olive: 'bg-olive-50 text-olive-900',
  cream: 'bg-olive-50 text-olive-900',
};

const ctaClasses: Record<string, string> = {
  terracotta: 'bg-terracotta-500 text-white hover:bg-terracotta-600',
  olive: 'bg-terracotta-500 text-white hover:bg-terracotta-600',
  cream: 'bg-terracotta-500 text-white hover:bg-terracotta-600',
};

const secondaryClasses: Record<string, string> = {
  terracotta: 'border-warm-sand text-olive-900 hover:bg-white',
  olive: 'border-warm-sand text-olive-900 hover:bg-white',
  cream: 'border-warm-sand text-olive-900 hover:bg-white',
};
---

<section class={`${bgClasses[variant]} py-16 md:py-20`}>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="bg-white border border-warm-sand rounded-[2rem] px-6 py-10 md:px-12 md:py-12 shadow-[0_2px_10px_rgba(0,0,0,0.04)]">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
    {subtitle && <p class="text-lg md:text-xl opacity-90 mb-8">{subtitle}</p>}
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={primaryCta.href} class={`inline-block font-semibold px-8 py-3 rounded-full transition-colors text-base ${ctaClasses[variant]}`}>
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class={`inline-block font-semibold px-8 py-3 rounded-full border transition-colors text-base ${secondaryClasses[variant]}`}>
          {secondaryCta.label}
        </a>
      )}
    </div>
    </div>
  </div>
</section>
