---
interface Card {
  icon?: string;
  title: string;
  description: string;
  href?: string;
  image?: string;
}

export interface Props {
  cards: Card[];
  columns?: 2 | 3 | 4;
  variant?: 'default' | 'compact';
}

const { cards, columns = 3, variant = 'default' } = Astro.props;
const gridCols = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-2 lg:grid-cols-4',
};
---

<div class={`grid grid-cols-1 ${gridCols[columns]} gap-6`}>
  {cards.map(card => (
    <div class={`bg-white rounded-2xl border border-warm-sand hover:shadow-[0_4px_12px_rgba(0,0,0,0.08)] transition-shadow ${variant === 'compact' ? 'p-4' : 'p-6'}`}>
      {card.image && (
        <img src={card.image} alt="" class="w-full h-48 object-cover rounded-lg mb-4" loading="lazy" />
      )}
      {card.icon && <div class="text-2xl mb-3 grayscale">{card.icon}</div>}
      <h3 class={`font-semibold text-olive-800 ${variant === 'compact' ? 'text-sm' : 'text-lg'} mb-2`}>
        {card.href ? <a href={card.href} class="hover:text-terracotta-500 transition-colors">{card.title}</a> : card.title}
      </h3>
      <p class={`text-slate-warm ${variant === 'compact' ? 'text-xs' : 'text-sm'} leading-relaxed`}>{card.description}</p>
    </div>
  ))}
</div>
