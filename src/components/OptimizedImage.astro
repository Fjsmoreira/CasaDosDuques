---
export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  aspectRatio?: string;
}

const { src, alt, width, height, loading = 'lazy', aspectRatio } = Astro.props;
---

<img
  src={src}
  alt={alt}
  {width}
  {height}
  {loading}
  decoding="async"
  class={Astro.props.class}
  style={aspectRatio ? { aspectRatio } : undefined}
/>
