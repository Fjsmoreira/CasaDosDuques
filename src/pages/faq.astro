---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { SITE_CONFIG } from '../data/site-config.ts';

const faqs = [
  {
    question: "What are the check-in and check-out times?",
    answer: "Check-in is from 16:00 and check-out is by 11:00. Early check-in or late check-out may be available on request — please contact us in advance."
  },
  {
    question: "How many guests can stay?",
    answer: "The house sleeps up to 8 guests across 4 bedrooms (6 adults maximum, plus 2 children and 1 baby). We have one double bed per room plus a bunk bed in the kids' room."
  },
  {
    question: "Is the pool open year-round?",
    answer: "The 8m swimming pool is typically available from May to September, depending on weather conditions. The pool has no gate or lock — children must be supervised at all times."
  },
  {
    question: "Is parking available?",
    answer: "Yes, free on-site parking is available at the property."
  },
  {
    question: "Are pets allowed?",
    answer: "Please contact us to discuss bringing pets. We may be able to accommodate well-behaved pets on a case-by-case basis."
  },
  {
    question: "Is there WiFi?",
    answer: "Yes, free high-speed WiFi is available throughout the house."
  },
  {
    question: "What's nearby?",
    answer: "The house is in the quiet historic town of Abiul. Within walking distance you'll find a café, mini-market, pharmacy, and restaurant. Pombal (with supermarkets, restaurants, and the castle) is a 10-minute drive. Beaches are 35-40 minutes away."
  },
  {
    question: "How far is the nearest beach?",
    answer: "The closest beach is Praia da Leirosa (37 min) followed by Praia do Osso da Baleia (38 min) in Pombal municipality. Figueira da Foz (47 min) and Nazaré (65 min) are popular day-trip destinations."
  },
  {
    question: "Is the house suitable for people with limited mobility?",
    answer: "The house has traditional features such as stairs and uneven surfaces that may not be suitable for guests with mobility issues. Please contact us to discuss your specific needs."
  },
  {
    question: "Is there air conditioning?",
    answer: "No, the house does not have air conditioning. The thick stone walls keep the house naturally cool in summer. Fans are available in the bedrooms."
  }
];
---

<BaseLayout
  title="Frequently Asked Questions — Casa dos Duques, Abiul, Pombal"
  description="FAQs about Casa dos Duques holiday home: check-in/out times, pool, parking, WiFi, nearby attractions, and more. Everything you need to know before your stay."
  canonical="/faq/"
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-4">Frequently Asked Questions</h1>
    <p class="text-slate-warm mb-8">Everything you need to know about your stay at Casa dos Duques.</p>

    <div class="space-y-4 mb-10">
      {
        faqs.map((faq, i) => (
          <details class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-olive-800 hover:text-terracotta-600 transition-colors list-none flex justify-between items-center">
              <span>{faq.question}</span>
              <span class="text-terracotta-500 text-xl transition-transform duration-200 group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-4 text-slate-warm leading-relaxed border-t border-warm-sand pt-3">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>

  <CTASection
    title="Still Have Questions?"
    subtitle="We're happy to help — get in touch with us"
    primaryCta={{ label: 'Contact Us', href: '/contact/' }}
    variant="terracotta"
  />
</BaseLayout>
