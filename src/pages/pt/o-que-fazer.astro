---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="O Que Fazer Perto de Pombal — Atividades, Praias, Passeios no Centro de Portugal"
  description="As melhores coisas para fazer perto de Pombal e Abiul: mosteiros UNESCO, praias, castelos, praias fluviais, caminhadas, gastronomia e atividades para famílias — tudo ao alcance da Casa dos Duques."
  canonical="/pt/o-que-fazer/"
  locale="pt"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">O Que Fazer Perto de Pombal</h1>
    <p class="text-slate-warm text-lg mb-8">
      Quer goste de história, natureza, praias ou gastronomia — a Casa dos Duques é a base perfeita 
      para umas férias inesquecíveis no Centro de Portugal.
    </p>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏰 Castelos & História</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Castelo de Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">Castelo dos Cavaleiros Templários do século XII com vistas panorâmicas</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Mosteiro da Batalha <span class="text-sm text-terracotta-600 font-normal">25 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Obra-prima gótica com as famosas Capelas Imperfeitas</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Tomar — Convento de Cristo <span class="text-sm text-terracotta-600 font-normal">30 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Fortaleza dos Templários com a impressionante janela manuelina</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Ruínas Romanas de Conímbriga <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">O povoado romano mais bem preservado de Portugal</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Praias & Costa</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia da Leirosa <span class="text-sm text-terracotta-600 font-normal">37 min</span></h3>
          <p class="text-sm text-slate-warm">Praia mais próxima — praia arenosa tranquila, perfeita para uma tarde</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia do Osso da Baleia <span class="text-sm text-terracotta-600 font-normal">38 min</span></h3>
          <p class="text-sm text-slate-warm">Fica no concelho de Pombal!</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Figueira da Foz <span class="text-sm text-terracotta-600 font-normal">47 min</span></h3>
          <p class="text-sm text-slate-warm">Grande resort de praia com praia arenosa de 2 km, casino e marginal</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Ondas gigantes mundialmente famosas e excelente marisco</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 Praias Fluviais</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia Fluvial do Mosteiro <span class="text-sm text-terracotta-600 font-normal">50 min</span></h3>
          <p class="text-sm text-slate-warm">Praia fluvial arenosa numa bela aldeia de xisto</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Penedo Furado <span class="text-sm text-terracotta-600 font-normal">60 min</span></h3>
          <p class="text-sm text-slate-warm">Espectacular cascata com piscinas naturais</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🥾 Natureza & Caminhadas</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Aldeias do Xisto <span class="text-sm text-terracotta-600 font-normal">45-60 min</span></h3>
          <p class="text-sm text-slate-warm">Aldeias tradicionais de xisto com percursos pedestres e praias fluviais</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Parque Natural da Serra da Estrela <span class="text-sm text-terracotta-600 font-normal">~2 h</span></h3>
          <p class="text-sm text-slate-warm">A maior cordilheira de Portugal — caminhadas, neve e vistas deslumbrantes</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Grutas de Mira de Aire <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Impressionante sistema de grutas calcárias com lagos subterrâneos</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🍷 Gastronomia & Vinhos</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restaurantes em Abiul <span class="text-sm text-terracotta-600 font-normal">A pé</span></h3>
          <p class="text-sm text-slate-warm">Casa dos Bispos (regional) e Quinta das Vinhas (3 min de carro)</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restauração em Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">6 restaurantes incluindo grelhados regionais, pizza, chinês e taberna tradicional</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Marisco na Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Peixe fresco e marisco no bairro piscatório</p>
        </div>
      </div>
    </section>
  </div>

  <CTASection
    title="Pronto para a Aventura?"
    subtitle="Reserve a Casa dos Duques e explore o melhor do Centro de Portugal"
    primaryCta={{ label: 'Reservar Agora', href: '/pt/reserva/' }}
    secondaryCta={{ label: 'Ver Passeios', href: '/pt/passeios/' }}
    variant="olive"
  />
</BaseLayout>
