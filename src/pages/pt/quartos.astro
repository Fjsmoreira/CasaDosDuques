---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Quartos — 4 Quartos para Até 8 Hóspedes | Casa dos Duques"
  description="4 quartos, 5 camas, 3 casas de banho na Casa dos Duques. Uma suite master, um quarto com beliche para crianças e dois quartos de casal. Dorme até 6 adultos + 2 crianças + 1 bebé."
  canonical="/pt/quartos/"
  locale="pt"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-4">Quartos — Dormir até 8 Hóspedes com Conforto</h1>
    <p class="text-slate-warm mb-8">4 quartos · 5 camas · 3 casas de banho · Dorme até 8 hóspedes (6 adultos + 2 crianças + 1 bebé)</p>
    
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/airbnb/a972d33d-086b-46ea-a63d-934ec57827ff.jpeg" alt="Quarto das crianças com beliche" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Quarto 1 — Quarto das Crianças</h2>
          <p class="text-sm text-slate-warm mb-3">1 beliche · Dorme 2</p>
          <p class="text-sm text-slate-warm">Um quarto acolhedor com beliche, perfeito para crianças ou hóspedes extra.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/airbnb/c1eb8904-37f7-4f82-99e7-cd539bafd98a.jpeg" alt="Quarto de casal com carácter tradicional" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Quarto 2 — Quarto de Casal</h2>
          <p class="text-sm text-slate-warm mb-3">1 cama de casal · Dorme 2</p>
          <p class="text-sm text-slate-warm">Confortável quarto de casal com carácter tradicional.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/airbnb/6cbce955-d2e0-480c-b318-7eb5e027eb85.jpeg" alt="Quarto de casal espaçoso com vista para o jardim" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Quarto 3 — Quarto de Casal</h2>
          <p class="text-sm text-slate-warm mb-3">1 cama de casal · Dorme 2</p>
          <p class="text-sm text-slate-warm">Quarto de casal espaçoso com vista para o jardim.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/airbnb/ba9a905b-2d7b-4741-ac8f-ceafe2288cf6.jpeg" alt="Suite master com casa de banho privativa" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Quarto 4 — Suite Master</h2>
          <p class="text-sm text-slate-warm mb-3">1 cama de casal · Casa de banho privativa · Dorme 2</p>
          <p class="text-sm text-slate-warm">Suite master com casa de banho privativa com banheira. O quarto mais privado da casa.</p>
        </div>
      </div>
    </div>

    <section class="bg-warm-cream rounded-xl p-6 mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Casas de Banho</h2>
      <ul class="space-y-2 text-slate-warm">
        <li>🛁 Casa de banho privativa (Quarto 4) — banheira</li>
        <li>🚿 Casa de banho partilhada 1 — chuveiro</li>
        <li>🚿 Casa de banho partilhada 2 — chuveiro</li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-6">Galeria de Quartos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <img src="/images/airbnb/a972d33d-086b-46ea-a63d-934ec57827ff.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/airbnb/c1eb8904-37f7-4f82-99e7-cd539bafd98a.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/airbnb/6cbce955-d2e0-480c-b318-7eb5e027eb85.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/airbnb/ba9a905b-2d7b-4741-ac8f-ceafe2288cf6.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/airbnb/04be686a-a4fe-484c-be4e-590aa81cf11a.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/airbnb/1b5f5cec-a4ff-402a-b6a8-ac852df5f7a3.jpeg" alt="Interior de quarto da Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
      </div>
    </section>
  </div>

  <CTASection
    title="Pronto para Reservar?"
    subtitle="Verifique a disponibilidade para a configuração de quartos que prefere"
    primaryCta={{ label: 'Ver Disponibilidade', href: '/pt/reserva/' }}
    variant="terracotta"
  />
</BaseLayout>
