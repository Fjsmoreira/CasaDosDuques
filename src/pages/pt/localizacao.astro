---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import MapSection from '../../components/MapSection.astro';
import { SITE_CONFIG } from '../../data/site-config.ts';
---

<BaseLayout
  title="Localização — Casa dos Duques em Abiul, Pombal, Centro de Portugal"
  description="Encontre a Casa dos Duques na histórica vila de Abiul, concelho de Pombal. 10 min de Pombal, 25 min da Batalha/Leiria, 35 min das praias. Lisboa 1,5h, Porto 1,5h."
  canonical="/pt/localizacao/"
  locale="pt"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Onde Estamos — Abiul, Pombal, Centro de Portugal</h1>
    
    <MapSection
      lat={SITE_CONFIG.coordinates.lat}
      lng={SITE_CONFIG.coordinates.lng}
      address={SITE_CONFIG.address.street}
      town={SITE_CONFIG.address.town}
      district={SITE_CONFIG.address.district}
      height="h-[300px] md:h-[400px]"
    />

    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-6">
        <h2 class="font-semibold text-lg text-olive-800 mb-3">📍 Factos Rápidos</h2>
        <ul class="space-y-2 text-sm text-slate-warm">
          <li><strong>Vila:</strong> {SITE_CONFIG.address.town}, {SITE_CONFIG.address.district}</li>
          <li><strong>Distrito:</strong> {SITE_CONFIG.address.region}</li>
          <li><strong>Região:</strong> Centro de Portugal</li>
          <li><strong>Registo AL:</strong> {SITE_CONFIG.alRegistration}</li>
        </ul>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-6">
        <h2 class="font-semibold text-lg text-olive-800 mb-3">🚗 Tempos de Carro</h2>
        <ul class="space-y-2 text-sm text-slate-warm">
          <li><strong>Pombal:</strong> 10 min</li>
          <li><strong>Leiria:</strong> 25 min</li>
          <li><strong>Batalha (UNESCO):</strong> 25 min</li>
          <li><strong>Praias:</strong> 35-40 min</li>
          <li><strong>Lisboa:</strong> ~1,5 h (172 km)</li>
          <li><strong>Porto:</strong> ~1,5 h (180 km)</li>
        </ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Sobre Abiul</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        Abiul é uma vila histórica no concelho de Pombal, com uma rica história que remonta a 
        1167, quando recebeu o seu primeiro foral real. Esteve historicamente ligada à poderosa 
        Casa de Aveiro e alberga aquela que é considerada a praça de touros mais antiga de Portugal.
      </p>
      <p class="text-slate-warm leading-relaxed">
        Hoje, Abiul é uma vila tranquila com um forte sentido de comunidade. O supermercado, 
        farmácia, cafés e restaurantes nas proximidades estão a poucos minutos a pé da casa.
      </p>
      <a href="/pt/guia/abiul/" class="inline-block text-terracotta-600 hover:text-terracotta-700 font-semibold mt-3">Ler o Guia de Abiul →</a>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Sobre Pombal</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        A apenas 10 minutos da casa, Pombal é uma cidade encantadora dominada pelo seu castelo 
        medieval dos Cavaleiros Templários. A cidade oferece excelentes compras (supermercados Aldi, Dias), 
        uma vasta seleção de restaurantes, bancos e todos os serviços essenciais.
      </p>
      <p class="text-slate-warm leading-relaxed">
        Pombal deu o nome ao Marquês de Pombal, o famoso primeiro-ministro português do século XVIII.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Centro de Portugal</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        A Casa dos Duques está perfeitamente posicionada para explorar o melhor do Centro de Portugal. 
        Quatro Patrimónios Mundiais da UNESCO estão a 30 minutos de carro: Mosteiro da Batalha, 
        Mosteiro de Alcobaça, Convento de Cristo em Tomar e a Universidade de Coimbra.
      </p>
    </section>
  </div>

  <CTASection
    title="Perfeitamente Localizado para Descobrir"
    subtitle="Reserve a sua estadia e explore o melhor do Centro de Portugal a partir da Casa dos Duques"
    primaryCta={{ label: 'Reservar Agora', href: '/pt/reserva/' }}
    variant="terracotta"
  />
</BaseLayout>
