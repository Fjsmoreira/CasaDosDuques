---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Things to Do Near Pombal — Activities, Beaches, Day Trips in Central Portugal"
  description="The best things to do near Pombal and Abiul: UNESCO monasteries, beaches, castles, river beaches, hiking, food, and family activities — all within easy reach of Casa dos Duques."
  canonical="/things-to-do/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Things to Do Near Pombal</h1>
    <p class="text-slate-warm text-lg mb-8">
      Whether you love history, nature, beaches, or food — Casa dos Duques is the perfect base 
      for an unforgettable holiday in Central Portugal.
    </p>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏰 Castles & History</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Pombal Castle <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">12th-century Knights Templar castle with panoramic views</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Batalha Monastery <span class="text-sm text-terracotta-600 font-normal">25 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Gothic masterpiece with the famous Unfinished Chapels</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Tomar — Convent of Christ <span class="text-sm text-terracotta-600 font-normal">30 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Knights Templar fortress with the stunning Manueline window</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Conímbriga Roman Ruins <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Best-preserved Roman settlement in Portugal</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Beaches & Coast</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia da Leirosa <span class="text-sm text-terracotta-600 font-normal">37 min</span></h3>
          <p class="text-sm text-slate-warm">Closest beach — quiet sandy beach perfect for an afternoon</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia do Osso da Baleia <span class="text-sm text-terracotta-600 font-normal">38 min</span></h3>
          <p class="text-sm text-slate-warm">In Pombal municipality itself!</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Figueira da Foz <span class="text-sm text-terracotta-600 font-normal">47 min</span></h3>
          <p class="text-sm text-slate-warm">Major beach resort with a 2km sandy beach, casino, promenade</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">World-famous giant waves and excellent seafood</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 River Beaches (Praias Fluviais)</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia Fluvial do Mosteiro <span class="text-sm text-terracotta-600 font-normal">50 min</span></h3>
          <p class="text-sm text-slate-warm">Sandy river beach in a beautiful schist village setting</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Penedo Furado <span class="text-sm text-terracotta-600 font-normal">60 min</span></h3>
          <p class="text-sm text-slate-warm">Spectacular waterfall with natural swimming pools</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🥾 Nature & Hiking</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Aldeias do Xisto <span class="text-sm text-terracotta-600 font-normal">45-60 min</span></h3>
          <p class="text-sm text-slate-warm">Traditional schist villages with walking trails and river beaches</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Serra da Estrela Natural Park <span class="text-sm text-terracotta-600 font-normal">~2 h</span></h3>
          <p class="text-sm text-slate-warm">Portugal's highest mountain range — hiking, snow, and stunning views</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Mira de Aire Caves <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Impressive limestone cave system with underground lakes</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🍷 Food & Wine</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restaurants in Abiul <span class="text-sm text-terracotta-600 font-normal">Walking distance</span></h3>
          <p class="text-sm text-slate-warm">Casa dos Bispos (regional) and Quinta das Vinhas (3 min drive)</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Pombal Dining <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">6 restaurants including regional grill, pizza, Chinese, and traditional taberna</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré Seafood <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Fresh fish and seafood in the fishing quarter</p>
        </div>
      </div>
    </section>
  </div>

  <CTASection
    title="Ready for Adventure?"
    subtitle="Book Casa dos Duques and explore the best of Central Portugal"
    primaryCta={{ label: 'Book Your Stay', href: '/booking/' }}
    secondaryCta={{ label: 'View Day Trips', href: '/day-trips/' }}
    variant="olive"
  />
</BaseLayout>
