---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Best Beaches Near Pombal — A Day at the Coast from Casa dos Duques"
  description="Discover the best beaches near Pombal and Abiul: Praia da Leirosa (37 min), Praia do Osso da Baleia (38 min), Figueira da Foz (47 min), Nazaré (65 min), and stunning river beaches."
  canonical="/beaches/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Best Beaches Near Pombal — A Day at the Coast from Casa dos Duques</h1>
    <p class="text-slate-warm mb-8">
      From Casa dos Duques, you're just 37 minutes from the nearest beach. Whether you want
      quiet sandy coves, world-famous surf breaks, or family-friendly river beaches — here are
      the best beaches within easy reach.
    </p>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Ocean Beaches</h2>
    <div class="space-y-4 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Praia da Leirosa</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">37 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Figueira da Foz municipality</p>
        <p class="text-sm text-slate-warm">The closest beach to Casa dos Duques. A quiet sandy beach perfect for a relaxing afternoon by the sea.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Praia do Osso da Baleia</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">38 min</span>
        </div>
        <p class="text-xs text-terracotta-600 font-medium mb-2">📍 In Pombal municipality itself!</p>
        <p class="text-sm text-slate-warm">The closest beach that's actually in Pombal municipality. Sandy beach with a relaxed vibe.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Praia do Pedrógão</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">45 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Leiria municipality</p>
        <p class="text-sm text-slate-warm">Sandy beach with a beautiful pine forest backdrop. Great for nature lovers.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Figueira da Foz</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">47 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Major beach resort</p>
        <p class="text-sm text-slate-warm">Portugal's largest beach resort. A 2km sandy city beach with a casino, promenade, and excellent restaurants.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Nazaré</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">65 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">World-famous waves</p>
        <p class="text-sm text-slate-warm">Home to the world's biggest waves (up to 30m). Visit the clifftop promenade at Sítio, ride the cable car, and enjoy fresh seafood.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">São Martinho do Porto</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">70 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Best family beach</p>
        <p class="text-sm text-slate-warm">A calm, shell-shaped bay — one of the safest beaches for children on the coast.</p>
      </div>
    </div>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 River Beaches (Praias Fluviais)</h2>
    <p class="text-slate-warm mb-4">No sea? No problem. Central Portugal has stunning river beaches with crystal-clear water.</p>
    <div class="space-y-4 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Praia Fluvial do Mosteiro</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">50 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Pedrógão Grande</p>
        <p class="text-sm text-slate-warm">The closest river beach. Sandy beach in a beautiful schist village setting. Perfect for a peaceful river swim.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start mb-2">
          <h3 class="font-semibold text-lg text-olive-800">Penedo Furado</h3>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">60 min</span>
        </div>
        <p class="text-xs text-slate-warm mb-2">Vila de Rei</p>
        <p class="text-sm text-slate-warm">Spectacular waterfall with natural swimming pools. One of the most beautiful river beaches in Central Portugal.</p>
      </div>
    </div>
  </div>

  <CTASection
    title="Our Pool is Always Ready Too"
    subtitle="Enjoy both beach days and poolside relaxation at Casa dos Duques"
    primaryCta={{ label: 'Book Your Stay', href: '/booking/' }}
    variant="terracotta"
  />
</BaseLayout>
