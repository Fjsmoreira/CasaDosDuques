---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Activités Près de Pombal — Que Faire, Plages, Excursions au Centre du Portugal"
  description="Les meilleures activités près de Pombal et Abiul : monastères UNESCO, plages, châteaux, plages fluviales, randonnée, gastronomie et activités familiales — tout à portée de main depuis Casa dos Duques."
  locale="fr"
  canonical="/fr/activites/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Activités Près de Pombal</h1>
    <p class="text-slate-warm text-lg mb-8">
      Que vous aimiez l'histoire, la nature, les plages ou la gastronomie — Casa dos Duques est la base parfaite 
      pour des vacances inoubliables au Centre du Portugal.
    </p>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏰 Châteaux & Histoire</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Château de Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">Château des Chevaliers Templiers du XIIe siècle avec vue panoramique</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Monastère de Batalha <span class="text-sm text-terracotta-600 font-normal">25 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Chef-d'œuvre gothique avec les célèbres Chapelles Imparfaites</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Tomar — Couvent du Christ <span class="text-sm text-terracotta-600 font-normal">30 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Forteresse des Templiers avec la superbe fenêtre manuéline</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Ruines Romaines de Conímbriga <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">La colonie romaine la mieux préservée du Portugal</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Plages & Côte</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia da Leirosa <span class="text-sm text-terracotta-600 font-normal">37 min</span></h3>
          <p class="text-sm text-slate-warm">Plage la plus proche — plage de sable calme parfaite pour un après-midi</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia do Osso da Baleia <span class="text-sm text-terracotta-600 font-normal">38 min</span></h3>
          <p class="text-sm text-slate-warm">Dans la municipalité de Pombal elle-même !</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Figueira da Foz <span class="text-sm text-terracotta-600 font-normal">47 min</span></h3>
          <p class="text-sm text-slate-warm">Grande station balnéaire avec une plage de sable de 2 km, casino, promenade</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Vagues géantes de renommée mondiale et excellents fruits de mer</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 Plages Fluviales (Praias Fluviais)</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia Fluvial do Mosteiro <span class="text-sm text-terracotta-600 font-normal">50 min</span></h3>
          <p class="text-sm text-slate-warm">Plage de sable en bord de rivière dans un magnifique village de schiste</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Penedo Furado <span class="text-sm text-terracotta-600 font-normal">60 min</span></h3>
          <p class="text-sm text-slate-warm">Cascade spectaculaire avec des piscines naturelles</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🥾 Nature & Randonnée</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Aldeias do Xisto <span class="text-sm text-terracotta-600 font-normal">45-60 min</span></h3>
          <p class="text-sm text-slate-warm">Villages traditionnels en schiste avec sentiers de randonnée et plages fluviales</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Parc Naturel de Serra da Estrela <span class="text-sm text-terracotta-600 font-normal">~2 h</span></h3>
          <p class="text-sm text-slate-warm">La plus haute chaîne de montagnes du Portugal — randonnée, neige et vues époustouflantes</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Grottes de Mira de Aire <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Impressionnant réseau de grottes calcaires avec lacs souterrains</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🍷 Gastronomie & Vin</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restaurants à Abiul <span class="text-sm text-terracotta-600 font-normal">Accessible à pied</span></h3>
          <p class="text-sm text-slate-warm">Casa dos Bispos (cuisine régionale) et Quinta das Vinhas (3 min en voiture)</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restaurants à Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">6 restaurants : grillades régionales, pizza, chinois et taberna traditionnelle</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Fruits de Mer à Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Poisson frais et fruits de mer dans le quartier des pêcheurs</p>
        </div>
      </div>
    </section>
  </div>

  <CTASection
    title="Prêt pour l'Aventure ?"
    subtitle="Réservez Casa dos Duques et explorez le meilleur du Centre du Portugal"
    primaryCta={{ label: 'Réserver', href: '/fr/reservation/' }}
    secondaryCta={{ label: 'Voir les Excursions', href: '/fr/excursions/' }}
    variant="olive"
  />
</BaseLayout>
