---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Chambres — Jusqu'à 8 Personnes en Tout Confort | Casa dos Duques"
  description="4 chambres, 5 lits, 3 salles de bain à Casa dos Duques. Une suite parentale, une chambre à lits superposés pour enfants, et deux chambres doubles. Capacité jusqu'à 6 adultes + 2 enfants + 1 bébé."
  locale="fr"
  canonical="/fr/chambres/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-4">Chambres — Jusqu'à 8 Personnes en Tout Confort</h1>
    <p class="text-slate-warm mb-8">4 chambres · 5 lits · 3 salles de bain · Capacité jusqu'à 8 personnes (6 adultes + 2 enfants + 1 bébé)</p>
    
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/room-1.jpg" alt="Chambre enfants avec lits superposés" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Chambre 1 — Chambre Enfants</h2>
          <p class="text-sm text-slate-warm mb-3">1 lit superposé · 2 personnes</p>
          <p class="text-sm text-slate-warm">Une chambre cosy avec un lit superposé, parfaite pour les enfants ou des invités supplémentaires.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/room-2.jpg" alt="Chambre double avec caractère traditionnel" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Chambre 2 — Chambre Double</h2>
          <p class="text-sm text-slate-warm mb-3">1 lit double · 2 personnes</p>
          <p class="text-sm text-slate-warm">Chambre double confortable avec un caractère traditionnel.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/room-3.jpg" alt="Chambre double spacieuse avec vue sur le jardin" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Chambre 3 — Chambre Double</h2>
          <p class="text-sm text-slate-warm mb-3">1 lit double · 2 personnes</p>
          <p class="text-sm text-slate-warm">Chambre double spacieuse avec vue sur le jardin.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/room-4.jpg" alt="Suite parentale avec salle de bain privative" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Chambre 4 — Suite Parentale</h2>
          <p class="text-sm text-slate-warm mb-3">1 lit double · Salle de bain privative · 2 personnes</p>
          <p class="text-sm text-slate-warm">Chambre parentale avec salle de bain privative et baignoire. La chambre la plus intime de la maison.</p>
        </div>
      </div>
    </div>

    <section class="bg-warm-cream rounded-xl p-6 mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Salles de Bain</h2>
      <ul class="space-y-2 text-slate-warm">
        <li>🛁 Salle de bain privative (Chambre 4) — baignoire</li>
        <li>🚿 Salle de bain partagée 1 — douche</li>
        <li>🚿 Salle de bain partagée 2 — douche</li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-6">Galerie des Chambres</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <img src="/images/30ecfe34-26b5-45b5-b729-3a338987a597.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/52f77659-d47c-4b83-9823-6762fbb714a9.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/a880a2a5-2a4c-4a69-bbf3-ee8b217829ae.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/aa5ccbfd-b90b-4beb-94ef-47bb2793d886.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/caac1c63-2ec3-40e0-ab60-8ffac86d6a4f.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/3421b389-d232-4fcd-831a-910850539d44.jpeg" alt="Vue intérieure d'une chambre" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
      </div>
    </section>
  </div>

  <CTASection
    title="Prêt à Réserver ?"
    subtitle="Vérifiez la disponibilité pour votre configuration de chambres préférée"
    primaryCta={{ label: 'Voir Disponibilités', href: '/fr/reservation/' }}
    variant="terracotta"
  />
</BaseLayout>
