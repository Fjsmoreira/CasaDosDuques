---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../../data/site-config.ts';
---

<BaseLayout
  title="Réserver Casa dos Duques — Maison de Vacances à Abiul, Pombal, Centre du Portugal"
  description="Réservez votre séjour à Casa dos Duques. Contactez-nous directement pour les meilleurs tarifs ou réservez via Airbnb. 8 personnes, piscine, jardin — vos vacances parfaites au Centre du Portugal."
  locale="fr"
  canonical="/fr/reservation/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Réservez Votre Séjour à Casa dos Duques</h1>
    <p class="text-slate-warm mb-8">
      Prêt à découvrir Casa dos Duques ? Vous pouvez réserver directement avec nous pour les meilleurs tarifs,
      ou via Airbnb. Nous sommes là pour rendre vos vacances parfaites.
    </p>

    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="bg-terracotta-50 rounded-xl p-8 text-center border border-terracotta-200">
        <div class="text-4xl mb-3">📧</div>
        <h2 class="text-xl font-semibold text-olive-800 mb-3">Réservez Directement</h2>
        <p class="text-sm text-slate-warm mb-4">
          Réservez directement avec nous pour les meilleurs tarifs et un service personnalisé.
          Envoyez-nous une demande et nous vous répondrons rapidement.
        </p>
        <a href="mailto:fernando@casadosduques.pt" class="inline-block bg-terracotta-500 hover:bg-terracotta-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
          E-mail : fernando@casadosduques.pt
        </a>
      </div>

      <div class="bg-white rounded-xl p-8 text-center border border-warm-sand shadow-sm">
        <div class="text-4xl mb-3">🏠</div>
        <h2 class="text-xl font-semibold text-olive-800 mb-3">Réservez sur Airbnb</h2>
        <p class="text-sm text-slate-warm mb-4">
          Consultez notre annonce Airbnb pour les disponibilités, les avis des voyageurs,
          et l'expérience complète. Noté 4,97/5 — Guest Favorite.
        </p>
        <a href={SITE_CONFIG.airbnbUrl} target="_blank" rel="noopener noreferrer" class="inline-block bg-white border border-terracotta-300 text-terracotta-600 hover:bg-terracotta-50 font-semibold px-6 py-3 rounded-lg transition-colors">
          Voir sur Airbnb →
        </a>
      </div>
    </div>

    <div class="bg-warm-cream rounded-xl p-6 mb-8">
      <h2 class="text-xl font-semibold text-olive-800 mb-3">Formulaire de Contact</h2>
      <p class="text-sm text-slate-warm mb-4">Envoyez-nous un message et nous vous répondrons sous 24 heures.</p>
      <form action="mailto:fernando@casadosduques.pt" method="GET" class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-olive-700 mb-1" for="name">Nom</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-olive-700 mb-1" for="email">E-mail</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-olive-700 mb-1" for="dates">Dates Souhaitées</label>
          <input type="text" id="dates" name="dates" placeholder="ex. 15-22 juillet 2026" class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-olive-700 mb-1" for="guests">Nombre de Personnes</label>
          <select id="guests" name="guests" class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none">
            <option value="1-2">1-2 personnes</option>
            <option value="3-4">3-4 personnes</option>
            <option value="5-6">5-6 personnes</option>
            <option value="7-8">7-8 personnes</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-olive-700 mb-1" for="message">Message</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none"></textarea>
        </div>
        <button type="submit" class="bg-terracotta-500 hover:bg-terracotta-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors">
          Envoyer la Demande
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
