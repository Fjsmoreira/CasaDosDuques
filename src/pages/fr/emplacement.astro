---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import MapSection from '../../components/MapSection.astro';
import { SITE_CONFIG } from '../../data/site-config.ts';
---

<BaseLayout
  title="Emplacement — Casa dos Duques à Abiul, Pombal, Centre du Portugal"
  description="Trouvez Casa dos Duques dans la ville historique d'Abiul, district de Pombal. 10 min de Pombal, 25 min de Batalha/Leiria, 35 min des plages. Lisbonne 1h30, Porto 1h30."
  locale="fr"
  canonical="/fr/emplacement/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Où Nous Sommes — Abiul, Pombal, Centre du Portugal</h1>
    
    <MapSection
      lat={SITE_CONFIG.coordinates.lat}
      lng={SITE_CONFIG.coordinates.lng}
      address={SITE_CONFIG.address.street}
      town={SITE_CONFIG.address.town}
      district={SITE_CONFIG.address.district}
      height="h-[300px] md:h-[400px]"
      client:load
    />

    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-6">
        <h2 class="font-semibold text-lg text-olive-800 mb-3">📍 Informations Pratiques</h2>
        <ul class="space-y-2 text-sm text-slate-warm">
          <li><strong>Ville :</strong> {SITE_CONFIG.address.town}, {SITE_CONFIG.address.district}</li>
          <li><strong>District :</strong> {SITE_CONFIG.address.region}</li>
          <li><strong>Région :</strong> Centre du Portugal</li>
          <li><strong>Enregistrement AL :</strong> {SITE_CONFIG.alRegistration}</li>
        </ul>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-6">
        <h2 class="font-semibold text-lg text-olive-800 mb-3">🚗 Temps de Trajet</h2>
        <ul class="space-y-2 text-sm text-slate-warm">
          <li><strong>Pombal :</strong> 10 min</li>
          <li><strong>Leiria :</strong> 25 min</li>
          <li><strong>Batalha (UNESCO) :</strong> 25 min</li>
          <li><strong>Plages :</strong> 35-40 min</li>
          <li><strong>Lisbonne :</strong> ~1h30 (172 km)</li>
          <li><strong>Porto :</strong> ~1h30 (180 km)</li>
        </ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">À Propos d'Abiul</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        Abiul est une ville historique de la municipalité de Pombal, avec une riche histoire remontant à 
        1167, année où elle reçut sa première charte royale. Historiquement liée à la puissante 
        Maison d'Aveiro, elle abrite ce qui serait la plus ancienne arène de taureaux du Portugal.
      </p>
      <p class="text-slate-warm leading-relaxed">
        Aujourd'hui, Abiul est une ville paisible avec un fort sentiment de communauté. Le supermarché, 
        la pharmacie, les cafés et les restaurants les plus proches sont tous accessibles à pied depuis la maison.
      </p>
      <a href="/guide/abiul/" class="inline-block text-terracotta-600 hover:text-terracotta-700 font-semibold mt-3">Lire le Guide d'Abiul →</a>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">À Propos de Pombal</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        À seulement 10 minutes de la maison, Pombal est une charmante ville dominée par son 
        château médiéval des Chevaliers Templiers. La ville offre d'excellentes possibilités de shopping (supermarchés Aldi, Dias), 
        un large choix de restaurants, des banques et tous les services essentiels.
      </p>
      <p class="text-slate-warm leading-relaxed">
        Pombal a donné son nom au Marquês de Pombal, le célèbre Premier ministre portugais du XVIIIe siècle.
      </p>
      <a href="/guide/pombal/" class="inline-block text-terracotta-600 hover:text-terracotta-700 font-semibold mt-3">Lire le Guide de Pombal →</a>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Au Cœur du Portugal Central</h2>
      <p class="text-slate-warm leading-relaxed mb-3">
        Casa dos Duques est idéalement située pour explorer le meilleur du Centre du Portugal. 
        Quatre sites classés au patrimoine mondial de l'UNESCO sont à moins de 30 minutes en voiture : le Monastère de Batalha, 
        le Monastère d'Alcobaça, le Couvent du Christ à Tomar et l'Université de Coimbra.
      </p>
      <a href="/guide/central-portugal/" class="inline-block text-terracotta-600 hover:text-terracotta-700 font-semibold mt-3">Explorer le Centre du Portugal →</a>
    </section>
  </div>

  <CTASection
    title="Parfaitement Situé pour la Découverte"
    subtitle="Réservez votre séjour et explorez le meilleur du Centre du Portugal depuis Casa dos Duques"
    primaryCta={{ label: 'Réserver', href: '/fr/reservation/' }}
    variant="terracotta"
  />
</BaseLayout>
