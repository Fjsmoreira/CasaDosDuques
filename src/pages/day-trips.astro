---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Best Day Trips from Pombal, Central Portugal — 4 UNESCO Sites Within 30 Min"
  description="The best day trips from Pombal and Casa dos Duques: 4 UNESCO sites within 30 min, stunning beaches, Roman ruins, and charming medieval towns. Plan your Central Portugal adventure."
  canonical="/day-trips/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-4">The Best Day Trips from Pombal, Central Portugal</h1>
    <p class="text-lg text-terracotta-600 font-semibold mb-6">Casa dos Duques is perfectly located: 4 UNESCO sites within 30 minutes</p>
    <p class="text-slate-warm mb-8">
      One of the best things about staying at Casa dos Duques is the location. Within a 25-55 minute 
      drive, you can explore an extraordinary variety of destinations — from UNESCO-listed monasteries 
      and medieval castles to stunning beaches and Roman ruins.
    </p>

    <div class="space-y-4 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🏛️ Coimbra</h3>
            <p class="text-xs text-terracotta-600 font-medium">UNESCO World Heritage</p>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">40 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">Home to one of Europe's oldest universities (1290), a historic hilltop city with the Joanina Library and Baroque University tower.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">⛪ Batalha Monastery</h3>
            <p class="text-xs text-terracotta-600 font-medium">UNESCO World Heritage</p>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">25 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">A Gothic masterpiece built to commemorate Portugal's victory at Aljubarrota (1385). Don't miss the Unfinished Chapels.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">⛪ Alcobaça Monastery</h3>
            <p class="text-xs text-terracotta-600 font-medium">UNESCO World Heritage</p>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">30 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">Cistercian abbey founded in 1153, housing the tombs of King Pedro I and Inês de Castro.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🏰 Tomar — Convent of Christ</h3>
            <p class="text-xs text-terracotta-600 font-medium">UNESCO World Heritage</p>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">30 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">A Knights Templar fortress-monastery with the famous Manueline window.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🏺 Conímbriga</h3>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">35 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">The best-preserved Roman settlement in Portugal, with extensive mosaic floors.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🏖️ Figueira da Foz</h3>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">47 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">Portugal's largest beach resort with a 2km sandy beach, casino, and promenade.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🏖️ Nazaré</h3>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">65 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">World-famous giant waves, clifftop promenade, cable car, and fresh seafood.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-semibold text-lg text-olive-800">🌊 Praia Fluvial do Mosteiro</h3>
          </div>
          <span class="text-sm bg-olive-50 px-3 py-1 rounded-full text-olive-700 font-medium">50 min</span>
        </div>
        <p class="text-sm text-slate-warm mt-2">Beautiful river beach in a schist village — perfect for a peaceful swim.</p>
      </div>
    </div>
  </div>

  <CTASection
    title="Book Your Stay and Explore"
    subtitle="Casa dos Duques — your perfect base for Central Portugal adventures"
    primaryCta={{ label: 'Book Your Stay', href: '/booking/' }}
    variant="terracotta"
  />
</BaseLayout>
