---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardGrid from '../../components/CardGrid.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Explore Central Portugal — Beaches, Castles & UNESCO Heritage from Pombal"
  description="Explore the best of Central Portugal from Casa dos Duques: 4 UNESCO sites within 30 min, stunning beaches, medieval castles, Roman ruins. Your perfect holiday base."
  canonical="/guide/central-portugal/"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Explore Central Portugal — Beaches, Castles & UNESCO Heritage</h1>
    <p class="text-slate-warm text-lg mb-8">
      Casa dos Duques is perfectly located to explore the very best of Central Portugal. 
      Four UNESCO World Heritage sites are within a 30-minute drive, and stunning beaches 
      are just 35-40 minutes away. Here are our top recommendations.
    </p>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏛️ UNESCO World Heritage Sites</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Batalha Monastery</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">25 min — UNESCO</p>
        <p class="text-sm text-slate-warm">A Gothic masterpiece built to commemorate Portugal's victory at the 1385 Battle of Aljubarrota. Don't miss the Unfinished Chapels.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Alcobaça Monastery</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">30 min — UNESCO</p>
        <p class="text-sm text-slate-warm">A Cistercian abbey founded in 1153, housing the ornate tombs of King Pedro I and Inês de Castro — Portugal's tragic love story.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Tomar — Convent of Christ</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">30 min — UNESCO</p>
        <p class="text-sm text-slate-warm">A Knights Templar fortress-monastery with the famous 16th-century Manueline window. One of Portugal's most extraordinary architectural works.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Coimbra University</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">40 min — UNESCO</p>
        <p class="text-sm text-slate-warm">One of Europe's oldest universities (1290), with the stunning Joanina Library and Baroque University tower overlooking the city.</p>
      </div>
    </div>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Beaches & Coast</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Figueira da Foz</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">47 min — Beach resort</p>
        <p class="text-sm text-slate-warm">The largest beach resort in central Portugal with a 2km sandy beach, casino, and excellent restaurants.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Nazaré</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">65 min — Big waves</p>
        <p class="text-sm text-slate-warm">World-famous for giant waves up to 30m. Visit the clifftop promenade and enjoy fresh seafood in the fishing quarter.</p>
      </div>
    </div>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 River Beaches (Praias Fluviais)</h2>
    <p class="text-slate-warm mb-4">No sea? No problem. Central Portugal has stunning river beaches with crystal-clear water:</p>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Praia Fluvial do Mosteiro</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">50 min — Pedrógão Grande</p>
        <p class="text-sm text-slate-warm">Sandy river beach in a beautiful schist village setting. Perfect for a peaceful river swim.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Penedo Furado</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">60 min — Vila de Rei</p>
        <p class="text-sm text-slate-warm">Spectacular waterfall with natural pools. One of the most beautiful river beaches in Central Portugal.</p>
      </div>
    </div>

    <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏺 History & Ruins</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Conímbriga</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">35 min — Roman ruins</p>
        <p class="text-sm text-slate-warm">The best-preserved Roman settlement in Portugal, with extensive mosaic floors, thermal baths, and an aqueduct.</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-5">
        <h3 class="font-semibold text-lg text-olive-800">Leiria Castle</h3>
        <p class="text-sm text-terracotta-600 font-medium mb-2">25 min — Medieval</p>
        <p class="text-sm text-slate-warm">A hilltop 12th-century castle with a compact historic centre and riverside promenade below.</p>
      </div>
    </div>
  </div>

  <CTASection
    title="Your Central Portugal Adventure Awaits"
    subtitle="Book Casa dos Duques and explore it all"
    primaryCta={{ label: 'Book Your Stay', href: '/booking/' }}
    variant="terracotta"
  />
</BaseLayout>
