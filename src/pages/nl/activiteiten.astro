---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Wat te Doen in de Buurt van Pombal — Activiteiten, Stranden, Daguitstapjes in Centraal Portugal"
  description="De beste dingen om te doen in de buurt van Pombal en Abiul: UNESCO-kloosters, stranden, kastelen, rivierstranden, wandelen, eten en familieactiviteiten — allemaal op korte afstand van Casa dos Duques."
  canonical="/nl/activiteiten/"
  locale="nl"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Wat te Doen in de Buurt van Pombal</h1>
    <p class="text-slate-warm text-lg mb-8">
      Of u nu houdt van geschiedenis, natuur, stranden of lekker eten — Casa dos Duques is de perfecte uitvalsbasis 
      voor een onvergetelijke vakantie in Centraal Portugal.
    </p>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏰 Kastelen & Geschiedenis</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Kasteel van Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">12e-eeuws Tempelierskasteel met panoramisch uitzicht</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Batalha-klooster <span class="text-sm text-terracotta-600 font-normal">25 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Gotisch meesterwerk met de beroemde Onvoltooide Kapellen</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Tomar — Convent van Christus <span class="text-sm text-terracotta-600 font-normal">30 min — UNESCO</span></h3>
          <p class="text-sm text-slate-warm">Tempeliersvesting met het prachtige Manuelijnse venster</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Conímbriga Romeinse Ruïnes <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Best bewaarde Romeinse nederzetting in Portugal</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🏖️ Stranden & Kust</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia da Leirosa <span class="text-sm text-terracotta-600 font-normal">37 min</span></h3>
          <p class="text-sm text-slate-warm">Dichtstbijzijnde strand — rustig zandstrand, perfect voor een middagje uit</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia do Osso da Baleia <span class="text-sm text-terracotta-600 font-normal">38 min</span></h3>
          <p class="text-sm text-slate-warm">In de gemeente Pombal zelf!</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Figueira da Foz <span class="text-sm text-terracotta-600 font-normal">47 min</span></h3>
          <p class="text-sm text-slate-warm">Grote badplaats met een 2 km zandstrand, casino, promenade</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Wereldberoemde reuzengolven en uitstekende visgerechten</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🌊 Rivierstranden (Praias Fluviais)</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Praia Fluvial do Mosteiro <span class="text-sm text-terracotta-600 font-normal">50 min</span></h3>
          <p class="text-sm text-slate-warm">Zandstrand aan de rivier in een prachtig schistdorp</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Penedo Furado <span class="text-sm text-terracotta-600 font-normal">60 min</span></h3>
          <p class="text-sm text-slate-warm">Spectaculaire waterval met natuurlijke zwembaden</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🥾 Natuur & Wandelen</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Aldeias do Xisto <span class="text-sm text-terracotta-600 font-normal">45-60 min</span></h3>
          <p class="text-sm text-slate-warm">Traditionele schistdorpen met wandelpaden en rivierstranden</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Serra da Estrela Natuurpark <span class="text-sm text-terracotta-600 font-normal">~2 uur</span></h3>
          <p class="text-sm text-slate-warm">Hoogste bergketen van Portugal — wandelen, sneeuw en adembenemende uitzichten</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Grotten van Mira de Aire <span class="text-sm text-terracotta-600 font-normal">35 min</span></h3>
          <p class="text-sm text-slate-warm">Indrukwekkend kalksteengrottenstelsel met ondergrondse meren</p>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">🍷 Eten & Wijn</h2>
      <div class="space-y-3">
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Restaurants in Abiul <span class="text-sm text-terracotta-600 font-normal">Op loopafstand</span></h3>
          <p class="text-sm text-slate-warm">Casa dos Bispos (regionaal) en Quinta das Vinhas (3 min rijden)</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Eten in Pombal <span class="text-sm text-terracotta-600 font-normal">10 min</span></h3>
          <p class="text-sm text-slate-warm">6 restaurants waaronder regionale grill, pizza, Chinees en traditionele taberna</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-warm-sand">
          <h3 class="font-semibold text-olive-800">Nazaré Visgerechten <span class="text-sm text-terracotta-600 font-normal">65 min</span></h3>
          <p class="text-sm text-slate-warm">Verse vis en zeevruchten in de visserswijk</p>
        </div>
      </div>
    </section>
  </div>

  <CTASection
    title="Klaar voor Avontuur?"
    subtitle="Boek Casa dos Duques en ontdek het beste van Centraal Portugal"
    primaryCta={{ label: 'Boek Uw Verblijf', href: '/nl/boeking/' }}
    secondaryCta={{ label: 'Bekijk Daguitstapjes', href: '/nl/daguitstapjes/' }}
    variant="olive"
  />
</BaseLayout>
