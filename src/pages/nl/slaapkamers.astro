---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="Slaapkamers — Tot 8 Gasten Comfortabel Overnachten | Casa dos Duques"
  description="4 slaapkamers, 5 bedden, 3 badkamers bij Casa dos Duques. Eén master ensuite, één kinderen-slaapkamer en twee tweepersoonskamers. Slaapt tot 6 volwassenen + 2 kinderen + 1 baby."
  canonical="/nl/slaapkamers/"
  locale="nl"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-4">Slaapkamers — Tot 8 Gasten Comfortabel Overnachten</h1>
    <p class="text-slate-warm mb-8">4 slaapkamers · 5 bedden · 3 badkamers · Tot 8 gasten (6 volwassenen + 2 kinderen + 1 baby)</p>
    
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/a972d33d-086b-46ea-a63d-934ec57827ff.jpeg" alt="Kinderkamer met stapelbed" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Slaapkamer 1 — Kinderkamer</h2>
          <p class="text-sm text-slate-warm mb-3">1 stapelbed · Slaapt 2</p>
          <p class="text-sm text-slate-warm">Een gezellige kamer met een stapelbed, ideaal voor kinderen of extra gasten.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/c1eb8904-37f7-4f82-99e7-cd539bafd98a.jpeg" alt="Tweepersoonskamer met traditioneel karakter" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Slaapkamer 2 — Tweepersoonskamer</h2>
          <p class="text-sm text-slate-warm mb-3">1 tweepersoonsbed · Slaapt 2</p>
          <p class="text-sm text-slate-warm">Comfortabele tweepersoonskamer met traditioneel karakter.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/6cbce955-d2e0-480c-b318-7eb5e027eb85.jpeg" alt="Ruime tweepersoonskamer met uitzicht op de tuin" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Slaapkamer 3 — Tweepersoonskamer</h2>
          <p class="text-sm text-slate-warm mb-3">1 tweepersoonsbed · Slaapt 2</p>
          <p class="text-sm text-slate-warm">Ruime tweepersoonskamer met uitzicht op de tuin.</p>
        </div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-warm-sand overflow-hidden">
        <img src="/images/f74a9a09-e91d-4d49-b205-f50e9d5bbe40.jpeg" alt="Master ensuite slaapkamer" class="h-48 w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-2">Slaapkamer 4 — Master Suite</h2>
          <p class="text-sm text-slate-warm mb-3">1 tweepersoonsbed · Ensuite badkamer · Slaapt 2</p>
          <p class="text-sm text-slate-warm">Master bedroom met eigen badkamer met bad. De meest privékamer van het huis.</p>
        </div>
      </div>
    </div>

    <section class="bg-warm-cream rounded-xl p-6 mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-4">Badkamers</h2>
      <ul class="space-y-2 text-slate-warm">
        <li>🛁 Ensuite badkamer (Slaapkamer 4) — bad</li>
        <li>🚿 Gedeelde badkamer 1 — douche</li>
        <li>🚿 Gedeelde badkamer 2 — douche</li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-olive-700 mb-6">Slaapkamer Galerij</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <img src="/images/a972d33d-086b-46ea-a63d-934ec57827ff.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/c1eb8904-37f7-4f82-99e7-cd539bafd98a.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/6cbce955-d2e0-480c-b318-7eb5e027eb85.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/f74a9a09-e91d-4d49-b205-f50e9d5bbe40.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/04be686a-a4fe-484c-be4e-590aa81cf11a.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
        <img src="/images/1b5f5cec-a4ff-402a-b6a8-ac852df5f7a3.jpeg" alt="Slaapkamerinterieur van Casa dos Duques" class="rounded-lg h-48 w-full object-cover" loading="lazy" />
      </div>
    </section>
  </div>

  <CTASection
    title="Klaar om te Boeken?"
    subtitle="Controleer de beschikbaarheid voor uw gewenste kamerconfiguratie"
    primaryCta={{ label: 'Beschikbaarheid Controleren', href: '/nl/boeking/' }}
    variant="terracotta"
  />
</BaseLayout>
