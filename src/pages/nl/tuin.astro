---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { exteriorPhotos, poolGardenPhotos, roomInteriorPhotos } from '../../data/photo-manifest';

---

<BaseLayout
  title="450m² Tuin & 8m Zwembad — Fotogalerij | Casa dos Duques"
  description="Bekijk onze complete fotogalerij van de 450m² tuin, 8m zwembad, huis exterieur en kamers van Casa dos Duques. Uw privé buitenparadijs in Abiul."
  canonical="/nl/tuin/"
  locale="nl"
>
  <!-- Hero Section -->
  <div class="max-w-6xl mx-auto px-4 pt-12 pb-6">
    <h1 class="text-4xl md:text-5xl font-bold text-olive-800 mb-4">450 m² Tuin & Zwembad — Fotogalerij</h1>
    <p class="text-lg text-slate-warm leading-relaxed max-w-3xl">
      Ontdek elke hoek van Casa dos Duques door onze complete fotocollectie.
      Van het zonnige zwembad en de weelderige tuin tot de charmante buitenkant en zorgvuldig
      ingerichte interieurs — bekijk het allemaal voordat u aankomt.
    </p>
  </div>

  <!-- Gallery Sections -->
  <div class="max-w-6xl mx-auto px-4 pb-12">

    <!-- Pool & Garden -->
    <section class="mb-16" id="pool-tuin">
      <h2 class="text-3xl font-bold text-olive-700 mb-2 flex items-center gap-3">
        <span class="text-3xl">🌿</span> Zwembad &amp; Tuin
      </h2>
      <p class="text-slate-warm mb-6 ml-1">Het hart van uw buitenverblijf — zwembad, loungeplekken en weelderig groen</p>
      <div class="gallery-grid columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {
          poolGardenPhotos.map((photo) => (
            <img
              src={photo.src}
              alt={photo.alt}
              class="gallery-thumb w-full rounded-xl shadow-md hover:shadow-xl transition-all duration-300 cursor-pointer object-cover break-inside-avoid"
              loading="lazy"
            />
          ))
        }
      </div>
    </section>

    <!-- House Exterior -->
    <section class="mb-16" id="huis-exterieur">
      <h2 class="text-3xl font-bold text-olive-700 mb-2 flex items-center gap-3">
        <span class="text-3xl">🏡</span> Huis Exterieur
      </h2>
      <p class="text-slate-warm mb-6 ml-1">De charmante gevel en omgeving van Casa dos Duques</p>
      <div class="gallery-grid columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {
          exteriorPhotos.map((photo) => (
            <img
              src={photo.src}
              alt={photo.alt}
              class="gallery-thumb w-full rounded-xl shadow-md hover:shadow-xl transition-all duration-300 cursor-pointer object-cover break-inside-avoid"
              loading="lazy"
            />
          ))
        }
      </div>
    </section>

    <!-- Rooms & Interiors -->
    <section class="mb-16" id="kamers-interieurs">
      <h2 class="text-3xl font-bold text-olive-700 mb-2 flex items-center gap-3">
        <span class="text-3xl">🛋️</span> Kamers &amp; Interieurs
      </h2>
      <p class="text-slate-warm mb-6 ml-1">Comfortabele, sfeervol ingerichte woonruimtes</p>
      <div class="gallery-grid columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {
          roomInteriorPhotos.map((photo) => (
            <img
              src={photo.src}
              alt={photo.alt}
              class="gallery-thumb w-full rounded-xl shadow-md hover:shadow-xl transition-all duration-300 cursor-pointer object-cover break-inside-avoid"
              loading="lazy"
            />
          ))
        }
      </div>
    </section>

  </div>

  <!-- Lightbox Overlay -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white/80 hover:text-white text-4xl z-10 w-12 h-12 flex items-center justify-center rounded-full bg-black/30 hover:bg-black/50 transition-colors">&times;</button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white text-5xl z-10 w-12 h-12 flex items-center justify-center rounded-full bg-black/30 hover:bg-black/50 transition-colors">&#8249;</button>
    <img id="lightbox-img" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" alt="Vergrote weergave" />
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white text-5xl z-10 w-12 h-12 flex items-center justify-center rounded-full bg-black/30 hover:bg-black/50 transition-colors">&#8250;</button>
  </div>

  <CTASection
    title="Beleef de Tuin"
    subtitle="Boek uw verblijf en geniet van uw privé buitenparadijs"
    primaryCta={{ label: 'Beschikbaarheid Controleren', href: '/nl/boeking/' }}
    variant="olive"
  />
</BaseLayout>

<script>
  // Vanilla JS Lightbox
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    let currentIndex = 0;
    let allImages = [];

    // Collect all gallery images
    document.querySelectorAll('.gallery-thumb').forEach((img, index) => {
      allImages.push(img);
      img.addEventListener('click', () => openLightbox(index));
    });

    function openLightbox(index) {
      currentIndex = index;
      updateLightboxImage();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function updateLightboxImage() {
      const img = allImages[currentIndex];
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function prevImage() {
      currentIndex = (currentIndex - 1 + allImages.length) % allImages.length;
      updateLightboxImage();
    }

    function nextImage() {
      currentIndex = (currentIndex + 1) % allImages.length;
      updateLightboxImage();
    }

    closeBtn.addEventListener('click', closeLightbox);
    prevBtn.addEventListener('click', prevImage);
    nextBtn.addEventListener('click', nextImage);

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('flex')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    });

    // Click outside image to close
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Touch swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) nextImage();
        else prevImage();
      }
    }, { passive: true });
  });
</script>

<style>
  /* Improve masonry rendering */
  .gallery-grid {
    column-gap: 1rem;
  }
  .gallery-grid > img {
    margin-bottom: 1rem;
    display: block;
  }
  @media (max-width: 639px) {
    .gallery-grid {
      columns: 1;
    }
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    .gallery-grid {
      columns: 2;
    }
  }
  @media (min-width: 1024px) {
    .gallery-grid {
      columns: 3;
    }
  }

  /* Hover zoom effect */
  .gallery-thumb {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .gallery-thumb:hover {
    transform: scale(1.02);
  }

  /* Lightbox animations */
  #lightbox {
    animation: fadeIn 0.2s ease;
  }
  #lightbox-img {
    animation: scaleIn 0.25s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes scaleIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* Section divider */
  section {
    scroll-margin-top: 2rem;
  }
</style>
