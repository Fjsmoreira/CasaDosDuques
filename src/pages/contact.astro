---
import BaseLayout from '../layouts/BaseLayout.astro';
import MapSection from '../components/MapSection.astro';
import { SITE_CONFIG } from '../data/site-config.ts';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Casa dos Duques',
  url: 'https://casadosduques.pt/contact/',
  contactPoint: {
    '@type': 'ContactPoint',
    email: SITE_CONFIG.contact.email,
    telephone: SITE_CONFIG.contact.phone,
    contactType: 'reservation',
  },
  location: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      streetAddress: SITE_CONFIG.address.street,
      addressLocality: SITE_CONFIG.address.town,
      postalCode: SITE_CONFIG.address.postcode,
      addressRegion: SITE_CONFIG.address.district,
      addressCountry: 'PT',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: SITE_CONFIG.coordinates.lat,
      longitude: SITE_CONFIG.coordinates.lng,
    },
  },
};
---

<BaseLayout
  title="Contact Casa dos Duques — Holiday Home in Abiul, Pombal, Central Portugal"
  description="Contact Fernando & Isabelle at Casa dos Duques. Email, phone, WhatsApp, or use our contact form. We look forward to welcoming you to Abiul, Pombal."
  canonical="/contact/"
  schema={schema}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-olive-800 mb-6">Contact Us</h1>
    <p class="text-slate-warm mb-8">
      We'd love to hear from you! Whether you have a question, want to check availability,
      or are ready to book — get in touch and we'll respond promptly.
    </p>

    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div>
        <div class="space-y-4">
          <div class="bg-warm-cream rounded-xl p-5">
            <h3 class="font-semibold text-olive-800 mb-1">📧 Email</h3>
            <a href="mailto:fernando@casadosduques.pt" class="text-terracotta-600 hover:underline">fernando@casadosduques.pt</a>
          </div>
          <div class="bg-warm-cream rounded-xl p-5">
            <h3 class="font-semibold text-olive-800 mb-1">📞 Phone / WhatsApp</h3>
            <p class="text-slate-warm">{SITE_CONFIG.contact.phone}</p>
          </div>
          <div class="bg-warm-cream rounded-xl p-5">
            <h3 class="font-semibold text-olive-800 mb-1">🏠 Address</h3>
            <p class="text-sm text-slate-warm">
              {SITE_CONFIG.address.street}<br />
              {SITE_CONFIG.address.town}, {SITE_CONFIG.address.postcode}<br />
              {SITE_CONFIG.address.district}, {SITE_CONFIG.address.country}
            </p>
          </div>
          <div class="bg-warm-cream rounded-xl p-5">
            <h3 class="font-semibold text-olive-800 mb-1">🔑 AL Registration</h3>
            <p class="text-sm text-slate-warm">{SITE_CONFIG.alRegistration} — Licensed Local Accommodation</p>
          </div>
        </div>
      </div>

      <div>
        <div class="bg-white rounded-xl shadow-sm border border-warm-sand p-6">
          <h2 class="text-xl font-semibold text-olive-800 mb-4">Send a Message</h2>
          <form action="mailto:fernando@casadosduques.pt" method="GET" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-olive-700 mb-1" for="name">Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-olive-700 mb-1" for="email">Email *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-olive-700 mb-1" for="message">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 rounded-lg border border-warm-sand bg-white focus:border-terracotta-400 focus:ring-1 focus:ring-terracotta-400 outline-none"></textarea>
            </div>
            <button type="submit" class="bg-terracotta-500 hover:bg-terracotta-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors w-full">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>

    <MapSection
      lat={SITE_CONFIG.coordinates.lat}
      lng={SITE_CONFIG.coordinates.lng}
      address={SITE_CONFIG.address.street}
      town={SITE_CONFIG.address.town}
      district={SITE_CONFIG.address.district}
      height="h-[300px] md:h-[400px]"
    />
  </div>
</BaseLayout>
